# LiveKit Cloud
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# xAI Grok — single key for the Realtime voice model.
# Get a key from https://console.x.ai/
XAI_API_KEY=your_xai_api_key

# --- Grok Realtime model knobs (all optional — sane defaults below) ---
# Default uses grok-voice-think-fast-1.0 (background reasoning, released
# 2026-04-25). Override only if you want to test a different xAI model.
GROK_REALTIME_MODEL=grok-voice-think-fast-1.0
GROK_REALTIME_BASE_URL=wss://api.x.ai/v1/realtime
# Voice (lowercase): ara (warm female, default), eve (energetic female),
# leo (authoritative male), rex (confident male), sal (neutral).
GROK_VOICE=ara
# 0.6-0.9 = natural conversation; lower = more rigid/deterministic.
GROK_TEMPERATURE=0.7

# --- Silence handling (10s prompt, 60s total -> hangup) ---
# Seconds of user silence before agent says "Are you still there?".
USER_AWAY_TIMEOUT=10
# Total seconds of silence (including the warning) before the call is
# auto-ended via log_verification(status="other").
SILENCE_TOTAL_SECONDS=60
# What the agent says when silence is first detected.
SILENCE_PROMPT_TEXT=Are you still there?

# --- Latency knobs (all optional, sane defaults below) ---
# AEC warmup blocks the agent from speaking for this many seconds after
# session.start. Default in livekit-agents is 3.0s. SIP audio is
# unidirectional through TCN's gateway so AEC isn't relevant — keep at 0.
AEC_WARMUP_DURATION=0
# Let the LLM start composing replies before the user fully ends a turn.
# Big mid-call latency win. Set to "false" only if you see prematurely-cut
# generations.
PREEMPTIVE_GENERATION=true
# How long after the user stops speaking before we declare turn-end.
# Lower = snappier, higher = fewer false interruptions.
MIN_ENDPOINTING_DELAY=0.4
MAX_ENDPOINTING_DELAY=3.0

# Existing Railway webhook server (Node app — unchanged)
RAILWAY_SERVER_URL=https://your-existing-railway-webhook.up.railway.app
