# LiveKit Cloud
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# OpenAI — used for STT (Whisper) AND the LLM
OPENAI_API_KEY=your_openai_api_key

# Google Gemini — used for TTS (gemini-2.5-flash-preview-tts)
# NOTE: this worker reads GEMINI_API_KEY (the LiveKit Google plugin's default
# env var is GOOGLE_API_KEY, but our deploy uses GEMINI_API_KEY — we wire it
# through explicitly in agent.py).
GEMINI_API_KEY=your_google_gemini_api_key

# --- Cascaded pipeline knobs (all optional, sensible defaults below) ---
# OpenAI LLM model. Use gpt-4o for harder verifications, gpt-4o-mini for cheaper/faster.
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_LLM_TEMPERATURE=0.7
# OpenAI STT model. whisper-1 is the only currently-supported value.
OPENAI_STT_MODEL=whisper-1
# Gemini TTS model. Other option: gemini-2.5-pro-preview-tts (slower, higher quality).
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# Gemini voice. Female conversational picks: Aoede, Leda, Kore, Vindemiatrix, Achird.
GEMINI_VOICE=Aoede

# Existing Railway webhook server (Node app — unchanged)
RAILWAY_SERVER_URL=https://your-existing-railway-webhook.up.railway.app
