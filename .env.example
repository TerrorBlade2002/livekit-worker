# LiveKit Cloud
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ---------------------------------------------------------------------------
# Cascaded pipeline (STT → LLM → TTS). Defaults below are the production stack
# and run through LiveKit Inference, which needs NO extra provider keys — only
# the LIVEKIT_* credentials above. Set a *_BACKEND to "plugin" to use a direct
# provider plugin with your own key (then set the matching *_API_KEY).
# ---------------------------------------------------------------------------

# Backend per stage: "inference" (default, lowest latency, single key) or "plugin"
STT_BACKEND=inference
LLM_BACKEND=inference
TTS_BACKEND=inference

# --- STT: Deepgram Flux (primary) | AssemblyAI Universal Streaming (A/B) ---
# STT_PROVIDER=deepgram_flux  -> inference model deepgram/flux-general
# STT_PROVIDER=assemblyai     -> inference model assemblyai/universal-streaming-english
STT_PROVIDER=deepgram_flux
STT_LANGUAGE=en
# Override the model id (inference id, or plugin model name in plugin mode):
# STT_MODEL=deepgram/flux-general
# Flux eager end-of-turn: lower = start the LLM sooner (range 0.3–0.9).
STT_EAGER_EOT_THRESHOLD=0.4
# STT_EOT_THRESHOLD=0.7
# Needed only in plugin mode (STT_BACKEND=plugin):
# DEEPGRAM_API_KEY=your_deepgram_api_key
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# --- LLM: OpenAI GPT-5.1 Chat (critical path) ---
# Default is the NON-reasoning gpt-5.1-chat-latest: GPT-5.1 quality without the
# reasoning latency (~1.3s vs ~2.2s TTFT measured).
#   - openai/gpt-4.1-mini  -> fastest (~0.9s TTFT), best for the ~870ms budget
#   - openai/gpt-5.1       -> full reasoning (uses LLM_REASONING_EFFORT); slowest
LLM_MODEL=openai/gpt-5.1-chat-latest
# Plugin-mode model name (LLM_BACKEND=plugin):
LLM_PLUGIN_MODEL=gpt-5.1-chat-latest
# Reasoning effort — applied ONLY to reasoning models (gpt-5*, o-series):
# low | medium | high. Ignored by non-reasoning models (the default chat model).
LLM_REASONING_EFFORT=low
# Temperature — applied only to NON-reasoning models (the default, gpt-4.1-mini).
LLM_TEMPERATURE=0.4
# OPENAI_API_KEY is required when LLM_BACKEND=plugin (see below).

# --- TTS: Cartesia Sonic 3.5 ---
TTS_MODEL=cartesia/sonic-3.5
TTS_PLUGIN_MODEL=sonic-3
# Voice id (default: Jacqueline — confident American female). Browse voices at
# https://play.cartesia.ai/voices
TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
TTS_LANGUAGE=en
# Needed only in plugin mode (TTS_BACKEND=plugin):
# CARTESIA_API_KEY=your_cartesia_api_key

# --- Turn detection & interruption ---
# TURN_DETECTION: "stt" (Deepgram Flux integrated EOT, default) | "model"
# (LiveKit TurnDetector) | "vad"
TURN_DETECTION=stt
# INTERRUPTION_MODE: "adaptive" (barge-in model — filters "uh-huh"/backchannel)
# | "vad"
INTERRUPTION_MODE=adaptive
INTERRUPTION_MIN_DURATION=0.5
INTERRUPTION_MIN_WORDS=0
# ENDPOINTING_MODE: "fixed" (default) | "dynamic" (adapts to pause statistics)
ENDPOINTING_MODE=fixed

# --- Telephony input cleanup ---
# Krisp background voice cancellation on the SIP audio. "bvc_telephony"
# (default), "bvc", or "off". Requires LiveKit Cloud; degrades gracefully.
NOISE_CANCELLATION=bvc_telephony

# OpenAI key — used by the default LLM in plugin mode, and harmless otherwise.
# Get a key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key

# --- Silence handling (10s prompt, 60s total -> hangup) ---
# Seconds of user silence before agent says "Are you still there?".
USER_AWAY_TIMEOUT=10
# Total seconds of silence (including the warning) before the call is
# auto-ended via log_verification(status="other").
SILENCE_TOTAL_SECONDS=60
# What the agent says when silence is first detected.
SILENCE_PROMPT_TEXT=Are you still there?

# --- Latency knobs (all optional, sane defaults below) ---
# AEC warmup blocks the agent from speaking for this many seconds after
# session.start. Default in livekit-agents is 3.0s. SIP audio is
# unidirectional through TCN's gateway so AEC isn't relevant — keep at 0.
AEC_WARMUP_DURATION=0
# Let the LLM start composing replies before the user fully ends a turn.
# Big mid-call latency win. Set to "false" only if you see prematurely-cut
# generations.
PREEMPTIVE_GENERATION=true
# How long after the user stops speaking before we declare turn-end.
# Lower = snappier, higher = fewer false interruptions. In STT turn-detection
# mode this adds to the Deepgram Flux end-of-turn signal.
MIN_ENDPOINTING_DELAY=0.4
MAX_ENDPOINTING_DELAY=3.0

# Existing Railway webhook server (Node app — unchanged)
RAILWAY_SERVER_URL=https://your-existing-railway-webhook.up.railway.app

# ---------------------------------------------------------------------------
# Observability — Prometheus / Grafana (see ../monitoring/README.md)
# ---------------------------------------------------------------------------
# Master switch.
METRICS_ENABLED=true
# How metrics leave the process:
#   scrape        -> exposes /metrics on METRICS_PORT (local dev + docker stack)
#   remote_write  -> pushes to Grafana Cloud (REQUIRED for the managed,
#                    scale-to-zero LiveKit Cloud deployment — no scrape port)
#   both | off
METRICS_MODE=scrape

# --- scrape mode ---
METRICS_PORT=9091
METRICS_ADDR=0.0.0.0

# --- remote_write mode ---
# Railway-hosted Prometheus (the chosen setup — see ../monitoring/railway/):
#   URL      = https://<your-prometheus>.up.railway.app/api/v1/write
#   USERNAME = vta                 (PROM_BASIC_AUTH_USER)
#   PASSWORD = <basic-auth password>
# Grafana Cloud alternative:
#   URL      = https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
#   USERNAME = numeric instance ID  PASSWORD = metrics:write token
METRICS_PUSH_URL=
METRICS_PUSH_USERNAME=
METRICS_PUSH_PASSWORD=
METRICS_PUSH_INTERVAL=15

# Series identity (keeps autoscaled replicas from colliding). Defaults are fine.
# METRICS_JOB=vta-emma
# METRICS_INSTANCE=auto-generated-per-replica

# ---------------------------------------------------------------------------
# Transcripts -> Loki (see ../monitoring/README.md)
# ---------------------------------------------------------------------------
# At the END of every call (agent hangup OR customer drop) the agent pushes the
# full transcript + a call-summary analytics record to Loki — available
# immediately instead of waiting on LiveKit Cloud's delayed publish. Capture is
# a no-op until LOKI_PUSH_URL is set.
#
#   Local docker stack: http://localhost:3100/loki/api/v1/push   (no auth)
#   Grafana Cloud Loki: https://logs-prod-XX.grafana.net/loki/api/v1/push
#                       USERNAME = numeric instance ID, PASSWORD = logs:write token
LOKI_PUSH_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
# X-Scope-OrgID for multi-tenant Loki (leave blank for single-tenant / Cloud).
# LOKI_TENANT=
# Max seconds to wait for the push at end-of-call (kept short so it can't
# stall shutdown).
LOKI_TIMEOUT=5
# LOKI_ENABLED=true   # explicit off-switch even when a URL is set
